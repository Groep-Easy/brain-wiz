{
  "name": "brain-wiz",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "src/*"
  ],
  "description": "Brain Wiz — local multiplayer knowledge & puzzle game",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "npm run build:libs && npm run build:server && npm run client:build && npm run host:build",
    "build:libs": "tsc -b src/shared src/config src/minigames",
    "build:server": "nest build",
    "start": "node --env-file=.env dist/server/index.js",
    "dev:server": "concurrently -k \"nest build --watch\" \"node --watch --env-file=.env dist/server/index.js\"",
    "dev": "concurrently -k \"npm run dev:server\" \"npm run client:dev\" \"npm run host:dev\"",
    "db:reset": "docker compose down -v",
    "lint": "npm run lint --workspaces --if-present && eslint tests",
    "lint:fix": "npm run lint:fix --workspaces --if-present && eslint tests --fix",
    "format": "prettier --write \"src/**/*.{ts,js,html,css,json}\" \"tests/**/*.ts\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,html,css,json}\" \"tests/**/*.ts\" \"docs/**/*.md\"",
    "test": "npm run lint:fix && npm run format && npm run test:project-checks",
    "test:project-checks": "npm run build:libs && tsc && tsc-alias && cd dist && node --env-file=../.env --test",
    "test:coverage": "npm run build:libs && tsc && tsc-alias && node -e \"require('node:fs').mkdirSync('coverage', { recursive: true })\" && cd dist && node --env-file=../.env --test --experimental-test-coverage --test-reporter=spec --test-reporter=lcov --test-reporter-destination=stdout --test-reporter-destination=../coverage/lcov.info",
    "test:shared": "npm run build:libs && tsc && tsc-alias && cd dist/tests/shared && node --test",
    "validate": "npm run lint && npm run format:check && npm run test",
    "client:dev": "vite --host --config src/client/vite.config.ts",
    "client:build": "vite build --config src/client/vite.config.ts",
    "host:dev": "vite --host --config src/host/vite.config.ts",
    "host:build": "vite build --config src/host/vite.config.ts"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/testing": "^11.1.24",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.2.5",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/platform-ws": "^11.1.24",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^11.1.24",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "express": "^4.18.3",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.16.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.4",
    "typeorm": "^1.0.0",
    "ws": "^8.18.0"
  },
  "optionalDependencies": {
    "@rolldown/binding-darwin-arm64": "^1.1.0",
    "@rolldown/binding-linux-x64-gnu": "^1.1.1",
    "lightningcss-darwin-arm64": "^1.32.0",
    "lightningcss-linux-x64-gnu": "^1.32.0"
  }
}
