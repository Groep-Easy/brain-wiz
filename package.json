{
  "name": "brain-wiz",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Brain Wiz — local multiplayer knowledge & puzzle game",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc && node dist/scripts/dev.js",
    "start": "node --env-file=.env dist/src/server/index.js",
    "lint": "eslint src tests config scripts",
    "lint:fix": "eslint src tests config scripts --fix",
    "format": "prettier --write \"src/**/*.{ts,js,html,css,json}\" \"tests/**/*.ts\" \"config/**/*.ts\" \"scripts/**/*.ts\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,html,css,json}\" \"tests/**/*.ts\" \"config/**/*.ts\" \"scripts/**/*.ts\" \"docs/**/*.md\"",
    "test": "tsc && cd dist && node --env-file=../.env --test",
    "test:server": "tsc && cd dist/tests/server && node --env-file=../../../.env --test",
    "test:shared": "tsc && cd dist/tests/shared && node --test",
    "validate": "npm run lint && npm run format:check && npm run test",
    "client:dev": "vite --config vite.client.config.ts",
    "client:build": "vite build --config vite.client.config.ts",
    "client:preview": "vite preview --config vite.client.config.ts",
    "host:dev": "vite --config vite.host.config.ts",
    "host:build": "vite build --config vite.host.config.ts",
    "host:preview": "vite preview --config vite.host.config.ts"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.22",
    "@types/express": "^4.17.21",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "typeorm-cli": "^1.0.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/platform-ws": "^10.4.4",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^10.4.4",
    "express": "^4.18.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.16.0",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.4",
    "typeorm": "^1.0.0",
    "ws": "^8.18.0"
  }
}
