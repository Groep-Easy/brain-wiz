{
  "name": "brain-wis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Brain Wis — local multiplayer knowledge & puzzle game",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc && node dist/scripts/dev.js",
    "start": "node dist/src/server/index.js",
    "lint": "eslint src tests config scripts",
    "lint:fix": "eslint src tests config scripts --fix",
    "format": "prettier --write \"src/**/*.{ts,js,html,css,json}\" \"tests/**/*.ts\" \"config/**/*.ts\" \"scripts/**/*.ts\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,html,css,json}\" \"tests/**/*.ts\" \"config/**/*.ts\" \"scripts/**/*.ts\" \"docs/**/*.md\"",
    "test": "tsc && cd dist && node --test",
    "test:server": "tsc && cd dist/tests/server && node --test",
    "test:shared": "tsc && cd dist/tests/shared && node --test",
    "validate": "npm run lint && npm run format:check && npm run test"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^25.9.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "dependencies": {
    "express": "^4.18.3",
    "socket.io": "^4.7.4"
  }
}
