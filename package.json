{
  "name": "brain-wiz",
  "version": "0.1.0",
  "private": true,
  "description": "Brain Wiz — local multiplayer knowledge & puzzle game",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "npm run build:server && npm run client:build && npm run host:build",
    "build:server": "nest build",
    "dev": "npm run dev:server",
    "dev:server": "nest build && concurrently -k \"nest build --watch\" \"node --env-file=.env --watch dist/server/index.js\"",
    "start": "node --env-file=.env dist/server/index.js",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.{ts,js,html,css,json}\" \"tests/**/*.ts\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,html,css,json}\" \"tests/**/*.ts\" \"docs/**/*.md\"",
    "test": "npm run lint:fix && npm run format && tsc && cd dist && node --env-file=../.env --test",
    "test:project-checks": "tsc && cd dist && node --env-file=../.env --test",
    "test:server": "tsc && cd dist/tests/server && node --env-file=../../../.env --test",
    "test:shared": "tsc && cd dist/tests/shared && node --test",
    "validate": "npm run lint && npm run format:check && npm run test",
    "client:dev": "vite --config vite.client.config.ts",
    "client:build": "vite build --config vite.client.config.ts",
    "client:preview": "vite preview --config vite.client.config.ts",
    "host:dev": "vite --config vite.host.config.ts",
    "host:build": "vite build --config vite.host.config.ts",
    "host:preview": "vite preview --config vite.host.config.ts"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/testing": "^11.1.24",
    "@types/express": "^4.17.21",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/platform-ws": "^11.1.24",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^11.1.24",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "express": "^4.18.3",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.16.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.4",
    "typeorm": "^1.0.0",
    "ws": "^8.18.0"
  }
}
