{
  "name": "brain-wis",
  "version": "0.1.0",
  "private": true,
  "description": "Brain Wis — local multiplayer knowledge & puzzle game",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "node scripts/dev.js",
    "start": "node src/server/index.js",
    "lint": "eslint src/ tests/ --ext .js",
    "lint:fix": "eslint src/ tests/ --ext .js --fix",
    "format": "prettier --write \"src/**/*.{js,html,css,json}\" \"tests/**/*.js\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"src/**/*.{js,html,css,json}\" \"tests/**/*.js\" \"docs/**/*.md\"",
    "test": "node --test tests/**/*.test.js",
    "test:server": "node --test tests/server/**/*.test.js",
    "test:shared": "node --test tests/shared/**/*.test.js",
    "validate": "npm run lint && npm run format:check && npm run test"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.5"
  },
  "dependencies": {
    "express": "^4.18.3",
    "socket.io": "^4.7.4"
  }
}
