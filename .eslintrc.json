{
  "root": true,
  "env": {
    "es2022": true,
    "node": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "no-console": "warn",
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "no-var": "error",
    "prefer-const": "error",
    "eqeqeq": ["error", "always"],
    "curly": ["error", "all"],
    "no-implicit-globals": "error",
    "no-shadow": "error"
  },
  "overrides": [
    {
      "files": ["src/host/**/*.js", "src/client/**/*.js"],
      "env": { "browser": true, "node": false }
    },
    {
      "files": ["tests/**/*.js"],
      "env": { "node": true },
      "rules": { "no-console": "off" }
    }
  ]
}
