# =============================================================================
# Brain Wiz — environment template. Copy to .env and fill in real values:
#   cp .env.example .env
# In the Docker deployment, docker-compose.yml overrides NODE_ENV=production,
# DB_HOST=db and TRUST_PROXY=true, so you do not need to set those for prod.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=development              # development | test | production
SERVER_PORT=3000                  # App listening port (nginx proxies to this)
SERVER_HOST=0.0.0.0               # Bind address. 0.0.0.0 so the proxy can reach it;
                                  # 127.0.0.1 to restrict to loopback (native runs).
SERVER_LOCATION=localhost         # Hostname used to build the logged base URL
TRUST_PROXY=false                 # true when running behind the nginx reverse proxy
ADMIN_API_KEY=dev-secret-key      # REST API global authentication key
SERVER_API_VERSION=1.0

# Allowed browser origins for REST CORS + the WebSocket origin check.
# Comma-separated, no spaces required.
#   - Development: leave empty — localhost:5173/5174 are allowed automatically.
#   - Production:  MUST list the deployed origin(s) or browsers/WebSockets are
#                  rejected, e.g. CORS_ORIGINS=https://your-server-ip-or-domain
CORS_ORIGINS=

# -----------------------------------------------------------------------------
# PostgreSQL — container credentials (consumed by the `db` service)
# The POSTGRES_* and DB_* values below must agree.
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=brainwiz
POSTGRES_DB=postgres

# App database connection
DB_HOST=localhost                 # localhost for native runs; compose sets this to `db`
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=brainwiz
DB_NAME=postgres
DB_SSL=false                      # true for managed Postgres

# Schema management (no migrations yet)
DB_SYNCHRONIZE=true               # DANGER: auto-creates schema from entities (dev only)
DB_DROP_SCHEMA=false              # DANGER: drops schema before sync

# Connection pool / tuning
DB_POOL_MIN=3
DB_POOL_MAX=10
DB_QUERY_TIMEOUT=30000            # ms
DB_IDLE_TIMEOUT=900000            # ms
DB_LOG_LEVEL=error                # query | error
DB_LOGGING_ENABLED=false

# -----------------------------------------------------------------------------
# Vite dev server ports (local development only)
# -----------------------------------------------------------------------------
HOST_PORT=5174
CLIENT_PORT=5173

# -----------------------------------------------------------------------------
# pgAdmin — only used with `--profile tools`
# -----------------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@brainwiz.local
PGADMIN_DEFAULT_PASSWORD=brainwiz
PGADMIN_CONFIG_SERVER_MODE="False"
PGADMIN_CONFIG_MASTER_PASSWORD_REQUIRED="False"
PGADMIN_CONFIG_LOGIN_DISABLED="True"

# -----------------------------------------------------------------------------
# Grafana — only used with `--profile observability`
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_EMAIL=admin@brainwiz.local
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_use_a_strong_unique_password
