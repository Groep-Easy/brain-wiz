# Copy this file to .env (which is gitignored) and fill in values.
# .env is NEVER committed to version control.

# ============================================================================
# Server Configuration
# ============================================================================
PORT=3000
NODE_ENV=development

# ============================================================================
# PostgreSQL Database Configuration
# ============================================================================
# CRITICAL: Fill these values before running the application
# For local development:
#   1. Create a PostgreSQL user: createuser brain_wiz_user -P
#   2. Create database: createdb -O brain_wiz_user brain_wiz_db
#   3. Fill in DB_PASSWORD with the user password

# Database connection
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=brain_wiz_user
DB_PASSWORD=your_secure_password_here
DB_NAME=brain_wiz_db

# SSL connection (set to true if connecting to managed PostgreSQL like AWS RDS)
DB_SSL=false

# Connection pooling
# Pool size scales with concurrent game rooms:
#   - min: minimum open connections (always available)
#   - max: maximum concurrent connections
# For multiplayer game server, use conservative values:
#   - Local dev: min=3, max=10
#   - Production: min=10, max=50
DB_POOL_MIN=3
DB_POOL_MAX=10

# Query timeout (milliseconds)
# Protects against slow queries blocking event loop
# Brain Wiz queries are fast (<100ms), so 30s is very safe
DB_QUERY_TIMEOUT=30000

# Connection idle timeout (milliseconds)
# Close pooled connections unused for this duration
# 15 minutes = 900000 ms (reasonable for game sessions)
DB_IDLE_TIMEOUT=900000

# Query logging level for debugging
# Options: 'query' (verbose), 'error' (errors only)
# Use 'query' during development, 'error' in production
DB_LOG_LEVEL=error

# Whether to log queries to console separately
# Use 'true' to debug specific performance issues
DB_LOGGING_ENABLED=false

# Schema synchronization (DANGER ZONE)
# - 'true': TypeORM auto-creates tables from entities (dev only)
# - 'false': Use migrations only (production - required)
# IMPORTANT: Set to 'false' and use migrations for safety
DB_SYNCHRONIZE=false

# Drop existing schema before sync/migration (VERY DANGEROUS)
# Only set to 'true' during local development if needed
# NEVER set to 'true' in production or CI/CD
DB_DROP_SCHEMA=false
