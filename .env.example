# Server Configuration
PORT=3000                        # App listening port
NODE_ENV=development             # development, test, or production
ADMIN_API_KEY=brainwiz           # REST API global authentication key
TRUST_PROXY=false                # set to true if deployed behind a trusted reverse proxy
CORS_ORIGINS=http://brain,https://brain,http://localhost,https://localhost,http://127.0.0.1,http://localhost:5173,http://localhost:5174,https://83.96.203.127

# Docker Postgres Setup (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=brainwiz
POSTGRES_DB=postgres

# Database Connection
DB_HOST=localhost
DB_PORT=5432                     # Postgres port
DB_USERNAME=postgres
DB_PASSWORD=brainwiz
DB_NAME=postgres
DB_SSL=false                     # set to true for managed Postgres
DB_SYNCHRONIZE=true              # DANGER: auto-creates schema (dev only)
DB_DROP_SCHEMA=false             # DANGER: drops schema before sync

# Database Tuning
DB_POOL_MIN=3                    # Minimum open connections
DB_POOL_MAX=10                   # Maximum concurrent connections
DB_QUERY_TIMEOUT=30000           # Query timeout in ms
DB_IDLE_TIMEOUT=900000           # Idle connection timeout in ms
DB_LOG_LEVEL=error               # query or error
DB_LOGGING_ENABLED=false         # console logging of queries

# pgAdmin web app credentials
PGADMIN_DEFAULT_EMAIL=admin@brainwis.com
PGADMIN_DEFAULT_PASSWORD=brainwiz

# Grafana credentials
GRAFANA_ADMIN_EMAIL=admin@brainwiz.local
GRAFANA_ADMIN_PASSWORD=brainwiz

SERVER_API_VERSION=1.0
