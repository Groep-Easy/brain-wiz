NODE_ENV=test                    # development, test, or production

# Server Configuration
SERVER_PORT=3000                 # App listening port
SERVER_LOCATION=localhost
ADMIN_API_KEY=dev-secret-key     # REST API global authentication key

# POSTGRES DATABASE Configuration
TRUST_PROXY=false                # set to true if deployed behind a trusted reverse proxy
CORS_ORIGINS=http://brain,https://brain,http://localhost,https://localhost,http://127.0.0.1,http://localhost:5173,http://localhost:5174

# Docker Postgres Setup (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ci_test_password
POSTGRES_DB=ci_test_postgres

# Database Connection
DB_HOST=127.0.0.1
DB_PORT=5432                     # Postgres port
DB_USERNAME=postgres
DB_PASSWORD=ci_test_password
DB_NAME=ci_test_postgres
DB_SSL=false                     # set to true for managed Postgres
DB_SYNCHRONIZE=true              # DANGER: auto-creates schema (dev only)
DB_DROP_SCHEMA=false             # DANGER: drops schema before sync

# Database Tuning
DB_POOL_MIN=1                    # Minimum open connections
DB_POOL_MAX=5                    # Maximum concurrent connections
DB_QUERY_TIMEOUT=30000           # Query timeout in ms
DB_IDLE_TIMEOUT=900000           # Idle connection timeout in ms
DB_LOG_LEVEL=error               # query or error
DB_LOGGING_ENABLED=false         # console logging of queries

# pgAdmin web app credentials
PGADMIN_DEFAULT_EMAIL=admin@brainwis.com
PGADMIN_DEFAULT_PASSWORD=brainwiz
PGADMIN_CONFIG_SERVER_MODE="True"
PGADMIN_CONFIG_MASTER_PASSWORD_REQUIRED="True"
PGADMIN_CONFIG_LOGIN_DISABLED="False"

# Grafana credentials
GRAFANA_ADMIN_EMAIL=admin@brainwiz.local
GRAFANA_ADMIN_PASSWORD=brainwiz

# Host Configuration
HOST_PORT=5174
# Client Configuration
CLIENT_PORT=5173

# API Configuration
SERVER_API_VERSION=1.0
